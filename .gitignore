# ----------------------------------------------------------------------
# Heavyweight Colab outputs — DO NOT commit.
# ----------------------------------------------------------------------
# These files are produced by `colab/setup.py:run_setup()` inside a real
# Colab session, on Google Drive under MyDrive/fall_detection/. They do
# NOT exist in this repo by default — when they do exist they live on
# Drive, not locally. If you see them locally it means a developer ran
# the setup outside Colab for smoke-testing; do not commit.
artifacts/pip_freeze.txt
logs/setup_run_log.json
artifacts/crops/
artifacts/skeletons/
artifacts/checkpoints/
# Anchored to repo root: this is the Drive metrics-output dir. WITHOUT the
# leading slash this also swallowed evaluation/metrics/ (project source).
/metrics/

# Raw and intermediate dataset material — lives on Drive only.
# The manifest references these by path; they are never in git.
# Anchored to repo root so it can't swallow a nested source dir named datasets/.
/datasets/
*.tar
*.tar.gz
*.mp4
*.avi
*.mov
*.npy
*.npz

# Model weights — downloaded by ultralytics / transformers / accelerate
# into the local runtime. NEVER commit; the env lock captures versions
# but the binary weights belong on Drive only (or not at all).
*.pt
*.pth
*.onnx
*.bin
*.safetensors
*.pkl
*.joblib

# Local secrets (defensive — none expected)
.env
*.local

# Internal AI-supervisor planning docs — kept LOCAL, not published to the
# public repo. context.txt is the living state doc; issues/ holds the PRD +
# per-issue specs. Untracked via `git rm --cached`; the files stay on disk.
/context.txt
/issues/